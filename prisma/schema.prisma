datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  USER
}

enum OrgRole {
  ADMIN
  FACILITATOR
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  role          Role      @default(USER)
  is_verified   Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  profile       Profile?
  organizations Organization[] @relation("OrgOwner")
  org_memberships OrgMember[]
  enrollments   Enrollment[]
  transactions  Transaction[]
  certificates  Certificate[]
}

model Profile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  first_name String
  last_name  String
  phone      String?
  avatar_url String?

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([phone])
}

model Organization {
  id          String   @id @default(uuid())
  owner_id    String
  name        String
  slug        String   @unique
  logo_url    String?
  brand_color String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  owner       User     @relation("OrgOwner", fields: [owner_id], references: [id])
  members     OrgMember[]
  programs    Program[]
}

model OrgMember {
  id       String   @id @default(uuid())
  org_id   String
  user_id  String
  role     OrgRole  @default(FACILITATOR)

  org      Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([org_id, user_id])
}

model Program {
  id            String        @id @default(uuid())
  org_id        String
  title         String
  description   String?
  price         Int           // Stored in Kobo/Cents
  currency      String        @default("NGN")
  status        ProgramStatus @default(DRAFT)
  cover_image   String?       
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  org           Organization  @relation(fields: [org_id], references: [id], onDelete: Cascade)
  cohorts       Cohort[]
}

model Cohort {
  id         String   @id @default(uuid())
  program_id String
  name       String   // e.g., "May Batch"
  start_date DateTime
  end_date   DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program    Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)
  sessions   Session[]
  enrollments Enrollment[]
  certificates Certificate[]
}

model Session {
  id             String   @id @default(uuid())
  cohort_id      String
  title          String
  start_time     DateTime
  end_time       DateTime
  meeting_link   String?
  recording_link String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  cohort         Cohort   @relation(fields: [cohort_id], references: [id], onDelete: Cascade)
}

model Enrollment {
  id               String           @id @default(uuid())
  user_id          String
  cohort_id        String
  status           EnrollmentStatus @default(ACTIVE)
  progress_percent Int              @default(0)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cohort           Cohort           @relation(fields: [cohort_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cohort_id])
}

model Transaction {
  id               String   @id @default(uuid())
  user_id          String
  reference        String   @unique
  amount           Int      // Stored in Kobo/Cents
  currency         String   @default("NGN")
  status           TransactionStatus @default(PENDING)
  gateway_response String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id])

  @@index([reference])
}

model Certificate {
  id         String   @id @default(uuid())
  user_id    String
  cohort_id  String
  issue_date DateTime @default(now())
  pdf_url    String
  revoked    Boolean  @default(false)

  user       User     @relation(fields: [user_id], references: [id])
  cohort     Cohort   @relation(fields: [cohort_id], references: [id])
}
